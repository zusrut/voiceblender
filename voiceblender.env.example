# VoiceBlender configuration — example with default values.
#
# Copy this file to `voiceblender.env` and adjust as needed:
#   cp voiceblender.env.example voiceblender.env
#
# `voiceblender.env` is intentionally untracked (it may hold credentials).
# Keep THIS file in sync with `internal/config/config.go` — every env var the
# server reads should appear here with its real default value.

# ---------------------------------------------------------------------------
# Identity
# ---------------------------------------------------------------------------
# Instance identifier; included in API responses and webhook events.
# Leave blank to auto-generate a UUID on each start.
INSTANCE_ID=

# ---------------------------------------------------------------------------
# SIP signalling
# ---------------------------------------------------------------------------
SIP_BIND_IP=127.0.0.1
# IPv6 address advertised in SDP/Contact/Via for v6 calls. Empty = v4-only.
SIP_BIND_IPV6=
# UDP socket bind. Empty = same as SIP_BIND_IP.
SIP_LISTEN_IP=
# IPv6 socket bind. Empty = same as SIP_BIND_IPV6.
SIP_LISTEN_IPV6=
# Public IPv4 address for NAT/Docker; used in Contact + SDP c= when set.
SIP_EXTERNAL_IP=
SIP_PORT=5060
# SIP-over-TLS port (typically 5061). Empty = TLS disabled.
SIP_TLS_PORT=
SIP_TLS_CERT=
SIP_TLS_KEY=
SIP_DEBUG=false
# FQDN advertised in From/Contact/Via on outbound SIP. Empty = use IP.
SIP_DOMAIN=
SIP_HOST=voiceblender
# Preference-ordered codec list (PCMU, PCMA, G722, opus, AMR-WB, AMR-NB).
SIP_CODECS=PCMU,PCMA
SIP_REFER_AUTO_DIAL=false
SIP_AUTO_RINGING=false
SIP_USE_SOURCE_SOCKET=false
SIP_JITTER_BUFFER_MS=0
SIP_JITTER_BUFFER_MAX_MS=300

# SIP REGISTER / AOR registry
SIP_REGISTRATION_DEFAULT_EXPIRES_SECONDS=3600
SIP_REGISTRATION_MAX_EXPIRES_SECONDS=7200
SIP_REGISTRATION_SWEEP_INTERVAL_MS=1000
SIP_REGISTRATION_ALLOW_MULTIPLE_CONTACTS=true

# SIP outbound REGISTER (trunks) — VoiceBlender as a UAC registering to an
# upstream SIP registrar/PBX. See POST /v1/sip/trunks.
SIP_OUTBOUND_REGISTRATION_DEFAULT_EXPIRES_SECONDS=3600
SIP_OUTBOUND_REGISTRATION_MIN_EXPIRES_SECONDS=60
SIP_OUTBOUND_REGISTRATION_MAX_EXPIRES_SECONDS=7200
SIP_OUTBOUND_REGISTRATION_REFRESH_RATIO=0.5
SIP_OUTBOUND_REGISTRATION_FAILURE_BACKOFF_MAX_MS=300000

# AMR-WB (G.722.2) — speech-mode ceiling 0..8, octet-aligned framing offer.
AMRWB_MODE=2
AMRWB_OCTET_ALIGNED=true

# AMR-NB — speech-mode ceiling 0..7, octet-aligned framing offer.
AMRNB_MODE=7
AMRNB_OCTET_ALIGNED=true

# ---------------------------------------------------------------------------
# HTTP API
# ---------------------------------------------------------------------------
HTTP_ADDR=:8080
# Comma-separated allowlist of IPs and CIDR ranges (v4 + v6 mixable).
# Empty = accept any source. Gates REST, /v1/vsi, /v1/legs/websocket,
# /v1/legs/moq, /metrics, and pprof.
# Examples: 127.0.0.1,10.0.0.0/8  |  2001:db8::/32,::1
ALLOWED_IPS=
# When true, leftmost X-Forwarded-For is used as the client IP for the
# ALLOWED_IPS check. Enable only behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=false

# ---------------------------------------------------------------------------
# Media / RTP
# ---------------------------------------------------------------------------
RTP_PORT_MIN=10000
RTP_PORT_MAX=20000
ICE_SERVERS=stun:stun.l.google.com:19302
# Comma-separated public IPs advertised as host ICE candidates (pion
# SetNAT1To1IPs). Set this when VB runs behind NAT/Docker and the gathered
# host interface IPs aren't routable from the remote WebRTC peer. Supports
# IPv4 and IPv6 literals. The literal value "auto" triggers STUN-based
# public-IP discovery at startup using the configured ICE_SERVERS. Leave
# empty to gather host candidates as-is.
WEBRTC_EXTERNAL_IPS=
DEFAULT_SAMPLE_RATE=16000
SPEECH_DETECTION_ENABLED=false
# Per-client buffer size on the /v1/vsi WebSocket; clamped to [16, 1_000_000].
VSI_EVENT_BUFFER_SIZE=256

# ---------------------------------------------------------------------------
# Recording / storage
# ---------------------------------------------------------------------------
RECORDING_DIR=/tmp/recordings
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PREFIX=
# AWS credentials for S3 uploads (and AWS Polly TTS when no per-request
# api_key is supplied) are resolved by the AWS SDK's default credential
# chain, not by VoiceBlender directly. In order of precedence:
#   1. Static env vars: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
#      AWS_SESSION_TOKEN (optional, for temporary creds)
#   2. AWS_PROFILE pointing at a section in ~/.aws/credentials
#   3. EC2 / ECS / EKS instance role (IMDSv2)
# AWS_REGION is consulted only if S3_REGION is empty.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=
# AWS_REGION is honored by the SDK only when S3_REGION above is empty.
AWS_REGION=

# ---------------------------------------------------------------------------
# TTS cache
# ---------------------------------------------------------------------------
TTS_CACHE_ENABLED=false
TTS_CACHE_DIR=/tmp/tts_cache
TTS_CACHE_INCLUDE_API_KEY=false

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
WEBHOOK_URL=
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Third-party AI / speech providers (per-request keys override these)
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=
VAPI_API_KEY=
DEEPGRAM_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
# Google Cloud TTS uses Application Default Credentials (ADC) when no
# per-request api_key is supplied. The Google SDK resolves them, not
# VoiceBlender directly. In order of precedence:
#   1. GOOGLE_APPLICATION_CREDENTIALS pointing at a service-account JSON file
#   2. gcloud user creds at ~/.config/gcloud/application_default_credentials.json
#   3. GCE / Cloud Run / GKE instance metadata
GOOGLE_APPLICATION_CREDENTIALS=

# ---------------------------------------------------------------------------
# MoQ (Media over QUIC) — experimental
# ---------------------------------------------------------------------------
MOQ_ENABLED=false
MOQ_LISTEN_ADDR=:8443
MOQ_TLS_CERT_FILE=
MOQ_TLS_KEY_FILE=
MOQ_OPUS_BITRATE=24000

# ---------------------------------------------------------------------------
# LiveKit
# ---------------------------------------------------------------------------
LIVEKIT_ENABLED=false
LIVEKIT_URL=
LIVEKIT_OPUS_BITRATE=24000
LIVEKIT_TOKEN_SIGNING_ENABLED=false
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_DEFAULT_TOKEN_TTL=6h

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
